# === Base de données ===
POSTGRES_PASSWORD=changeme_dev
DATABASE_URL=postgresql+asyncpg://tvp:changeme_dev@postgres:5432/tvp

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Sécurité / JWT ===
# Générer une vraie clé : openssl rand -hex 32
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# === Application ===
ENVIRONMENT=development
API_BASE_URL=http://localhost:8000

# === Fournisseur Maxityre / AD Tyres ===
MAXITYRE_BASE_URL=https://api.maxityre.com
MAXITYRE_SITE_ID=4
# Identifiants à renseigner (NE JAMAIS committer le .env réel) :
MAXITYRE_USERNAME=
MAXITYRE_PASSWORD=
MAXITYRE_CACHE_TTL=600

# === Paiement ===
# "simulated" = dev (aucun contrat). "sogecommerce" = paiement reel.
PAYMENT_PROVIDER=simulated
# Back Office Sogecommerce -> Parametrage -> Cles d'API REST.
# Cles de TEST : le mot de passe API commence par 'testpassword_'.
# Passage en prod = remplacer par les cles de production (rien d'autre).
SOGECOMMERCE_SHOP_ID=
SOGECOMMERCE_API_PASSWORD=
# Cle HMAC-SHA256 (2e cle, sert a verifier la signature des IPN) :
SOGECOMMERCE_HMAC_KEY=
# URL publique que Sogecommerce appelle pour notifier le paiement.
# En local + test : utiliser un tunnel (ngrok) car la banque doit
# pouvoir joindre cette URL depuis l'exterieur.
SOGECOMMERCE_IPN_URL=https://tousvospneus.com/payment/ipn
